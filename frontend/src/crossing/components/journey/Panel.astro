---
import type { PanelConfig, CardVariant, PanelMidProp } from '../../types';
import SeaWater from '../water/SeaWater.astro';
import { buoySvg, mooringRopeSvg } from '../../assets/characters';
import {
  getIllustration,
  getPanelIcon,
  panelLogbookChartSvg,
  mooredBoatSvg,
  seagullSmallSvg,
  smallDorySvg,
  kelpSvg,
  pierPostSvg,
  lobsterTrapSvg,
  distantSailSvg,
  waterRippleSvg,
} from '../../assets/svg';
import { SPONSORS, HARBOUR_BOAT_SLOTS } from '../../config/sponsors';
import { PANELS } from '../../config/panels';

interface Props {
  config: PanelConfig;
}

const { config } = Astro.props;
const panelIndex = PANELS.findIndex((p) => p.id === config.id);

const illustration = getIllustration(config.illustration);
const panelIcon = getPanelIcon(config.illustration);
const logbookChart = panelLogbookChartSvg(config.routeCenterX, config.waypoint, panelIndex, config.id);

const midPropSvg: Record<PanelMidProp, string> = {
  buoy: buoySvg,
  rope: mooringRopeSvg,
  gull: seagullSmallSvg,
  dory: smallDorySvg,
  kelp: kelpSvg,
  pier: pierPostSvg,
  trap: lobsterTrapSvg,
  sail: distantSailSvg,
  ripple: waterRippleSvg,
};

const cardVariantClass: Record<CardVariant, string> = {
  log: 'panel-glass--log',
  workshop: 'panel-glass--workshop',
  harbour: 'panel-glass--harbour',
  gangway: 'panel-glass--gangway',
};

const panelStyle = {
  '--panel-chart-left': config.layout.chartLeft,
  '--panel-chart-rotate': config.layout.chartRotate,
  '--panel-illu-scale': config.layout.illuScale,
  '--panel-card-right': config.layout.cardRight,
};
---

<article
  data-panel
  data-panel-id={config.id}
  data-card-variant={config.cardVariant}
  data-scene-accent={config.sceneAccent}
  style={panelStyle}
  class:list={[
    'horizontal-panel relative flex-shrink-0 min-h-screen md:h-screen md:overflow-visible overflow-hidden',
    `panel--${config.id}`,
    config.cardVariant === 'gangway' && 'panel-field--gangway',
  ]}
>
  <div class="panel-scene__base absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-0" aria-hidden="true"></div>

  <div
    data-panel-bg
    class="panel-scene__tint absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-[1] opacity-0 pointer-events-none"
    style={`background: ${config.bgGradient}`}
    aria-hidden="true"
  ></div>

  <div
    data-panel-accent
    class:list={[
      'panel-scene-accent absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-[2] opacity-0 pointer-events-none',
      `panel-scene-accent--${config.sceneAccent}`,
    ]}
    aria-hidden="true"
  ></div>

  <div class="panel-edge-feather absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-[3] pointer-events-none" aria-hidden="true"></div>

  <div class="panel-vignette absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] pointer-events-none z-[4]" aria-hidden="true"></div>

  {
    config.sceneAccent === 'workshop-squall' && (
      <div class="panel-scene-rain absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-[2] opacity-0 pointer-events-none overflow-hidden" data-panel-rain aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => (
          <span
            class="panel-scene-rain__drop absolute w-px h-12 bg-gradient-to-b from-white/35 to-transparent"
            style={`left:${4 + i * 5.5}%; top:${(i % 5) * 18}%; transform: rotate(14deg);`}
          />
        ))}
      </div>
    )
  }

  <div class="md:hidden">
    <SeaWater variant="panel" />
  </div>

  {
    config.cardVariant === 'gangway' && (
      <div class="panel-gangway-halo absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] pointer-events-none z-[1]" aria-hidden="true"></div>
    )
  }

  <div class="panel-layout absolute inset-x-0 top-0 bottom-[18vh] md:bottom-[20vh] z-[10] w-full pointer-events-none">
    <div data-panel-art class="panel-scene relative min-h-0 min-w-0 h-full overflow-visible">
      {
        !config.hideChart && (
          <div
            data-panel-chart
            class="panel-chart-card absolute z-[8] pointer-events-none"
            set:html={logbookChart}
            aria-hidden="true"
          ></div>
        )
      }

      <div
        data-panel-illustration
        class="panel-scene__illu absolute z-[4] pointer-events-none"
        set:html={illustration}
      ></div>

      <div
        data-panel-mid
        class="panel-mid-prop absolute z-[7] pointer-events-none"
        class:list={[config.midPropPositions.primary]}
        set:html={midPropSvg[config.midProp]}
        aria-hidden="true"
      ></div>

      <div
        data-panel-mid-secondary
        class="panel-mid-prop absolute z-[6] pointer-events-none opacity-85"
        class:list={[config.midPropPositions.secondary]}
        set:html={midPropSvg[config.sceneProp2]}
        aria-hidden="true"
      ></div>

      {
        config.sceneProp3 && config.midPropPositions.tertiary && (
          <div
            data-panel-mid-tertiary
            class="panel-mid-prop absolute z-[5] pointer-events-none opacity-75"
            class:list={[config.midPropPositions.tertiary]}
            set:html={midPropSvg[config.sceneProp3]}
            aria-hidden="true"
          ></div>
        )
      }

      {
        config.sponsorHarbour && (
          <div
            data-panel-fg
            class="panel-harbour-fleet absolute inset-x-0 bottom-0 h-[42%] pointer-events-none z-[6]"
          >
            {SPONSORS.map((s, i) => {
              const slot = HARBOUR_BOAT_SLOTS[i];
              if (!slot) return null;
              return (
                <div
                  class="panel-harbour-boat-slot absolute pointer-events-auto"
                  style={`left:${slot.left};bottom:${slot.bottom};width:${slot.width};z-index:${slot.z};--boat-scale:${slot.scale};--boat-rotate:${slot.rotate ?? 0}deg`}
                >
                  <div
                    data-harbour-boat
                    class="panel-harbour-boat"
                    title={s.name}
                    set:html={mooredBoatSvg(s.name.slice(0, 8), s.color, s.pennant ?? '#c0392b')}
                  />
                </div>
              );
            })}
          </div>
        )
      }

      <div
        class="panel-mobile-traveler md:hidden absolute top-[min(20vh,180px)] z-[7] w-16 h-12 pointer-events-none opacity-90 left-[22%]"
        data-panel-traveler
        aria-hidden="true"
      >
        <div class="drop-shadow-lg w-full h-full" set:html={smallDorySvg}></div>
      </div>

      <div
        data-journey-pop
        class="panel-journey-pop label-caps absolute z-[9] pointer-events-none flex"
        aria-hidden="true"
      >
        <span class="panel-journey-pop__pin" aria-hidden="true"></span>
        <span class="panel-journey-pop__text">{config.popLabel}</span>
      </div>
    </div>

    <div
      class="panel-stage relative flex items-end md:items-center justify-center md:justify-end px-5 pb-8 pt-4 md:pl-4 md:pr-[var(--panel-card-right,4%)] md:py-0 pointer-events-none min-h-0 min-w-0 h-full overflow-visible"
    >
      <div
        data-panel-content
        class:list={[
          'panel-glass panel-glass-card panel-glass-card--anchored relative w-full text-white px-5 py-7 md:px-6 md:py-8 pointer-events-auto',
          cardVariantClass[config.cardVariant],
          config.cardVariant === 'log' && 'text-left',
          config.cardVariant === 'harbour' && 'text-left',
        ]}
      >
        {
          config.cardVariant === 'workshop' && (
            <div class="panel-rain-on-glass absolute inset-0 z-20 pointer-events-none overflow-hidden rounded-[inherit]" aria-hidden="true">
              {Array.from({ length: 14 }).map((_, i) => (
                <span
                  data-rain-streak
                  class="rain-streak absolute w-px h-10 bg-gradient-to-b from-white/60 to-transparent"
                  style={`left:${8 + i * 6.5}%; top:${(i % 4) * 22}%;`}
                />
              ))}
            </div>
          )
        }

        <span class="panel-waypoint-badge label-caps text-logbook-amber block mb-3 relative z-10">
          Waypoint {config.waypoint}
        </span>
        <p class="font-body text-sm md:text-[0.92rem] text-white/78 mb-4 leading-snug border-b border-white/12 pb-3 relative z-10 italic">
          {config.logbookEntry}
        </p>

        <div class="panel-icon-wrap md:hidden inline-flex items-center justify-center mb-3 p-2.5 rounded-full bg-white/10 ring-1 ring-white/15 w-12 h-12 relative z-10" aria-hidden="true">
          <span class="w-8 h-8 block" set:html={panelIcon}></span>
        </div>

        <h3 data-panel-title data-scramble-heading class="type-display-lg text-white relative z-10 leading-tight">
          {config.title}
        </h3>
        <p data-panel-desc class="mt-3 text-base md:text-[1.05rem] text-white/90 font-body leading-relaxed relative z-10">
          {config.description}
        </p>

        {
          config.marginNote && (
            <p class="mt-4 text-[0.65rem] uppercase tracking-[0.22em] text-white/55 font-label relative z-10 hidden sm:block">
              {config.marginNote}
            </p>
          )
        }
      </div>
    </div>
  </div>
</article>
