---
// Served from public/mascots/ (see scripts/copy-mascots.mjs) — avoids WSL absolute-path dev errors.
const mascotFrames = ['/mascots/group-2.svg', '/mascots/group-3.svg', '/mascots/group-4.svg'];
// Speech bubble image that sits next to the beaver (frame 1 only).
import textBubble from '../assets/text-bubble.png';
// Decorative leaf for the top-left corner.
import cornerLeaf from '../assets/corner-leaf.png';
// Hanging foliage for the top-right corner.
import topLeaves from '../assets/leaves.png';
import { Highlighter } from '@/components/ui/highlighter';

const teamLinks = [
	{ label: 'Alys', href: '/alysibak' },
	{ label: 'Name 2', href: '' },
	{ label: 'Name 3', href: '' },
	{ label: 'Name 4', href: '' },
];

---

<img
	class="home__corner-leaf"
	data-corner-leaf
	src={cornerLeaf.src}
	alt=""
	width={cornerLeaf.width}
	height={cornerLeaf.height}
	decoding="async"
	aria-hidden="true"
/>

<img
	class="home__top-leaves"
	data-top-leaves
	src={topLeaves.src}
	alt=""
	width={topLeaves.width}
	height={topLeaves.height}
	decoding="async"
	aria-hidden="true"
/>

<main class="home" aria-label="Site showcase">
	<div class="home__content">
		<h1 class="home__title">HC27 - Tech Onboarding </h1>
		<p class="home__lead">
			Onboarding task:{' '}
			<Highlighter client:load action="highlight" color="#fde68a">
				build your own page
			</Highlighter>
			,{' '}
			<Highlighter client:load action="underline" color="#f97316">
				add it below
			</Highlighter>
			, and{' '}
			<Highlighter client:load action="highlight" color="#bae6fd">
				link back to this home screen
			</Highlighter>{' '}
			when you are done.
		</p>

		<nav class="home__nav" aria-label="Showcase pages">
			{
				teamLinks.map((link) => (
					<a class="home__button" href={link.href}>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>

	<!-- Bottom mascot area: frames stacked; script toggles visibility (no client src swap). -->
	<div class="home__mascot">
		<div class="home__mascot-frames">
			{
				mascotFrames.map((frame, index) => (
					<img
						class:list={[
							'home__mascot-img',
							{ 'home__mascot-img--active': index === 0 },
						]}
						data-mascot-frame
						src={frame}
						alt=""
						width="63"
						height="67"
						decoding="async"
					/>
				))
			}
		</div>
		<!-- "Let's get started" bubble — only visible on the first mascot frame. -->
		<img
			class="home__mascot-bubble home__mascot-bubble--visible"
			data-mascot-bubble
			src={textBubble.src}
			alt=""
			width={textBubble.width}
			height={textBubble.height}
			decoding="async"
		/>
	</div>
</main>

<script>
	const frames = document.querySelectorAll('[data-mascot-frame]');
	const bubble = document.querySelector('[data-mascot-bubble]');
	if (frames.length < 2) return;

	const group2Index = 0;
	const setBubbleVisible = (index) => {
		bubble?.classList.toggle('home__mascot-bubble--visible', index === group2Index);
	};

	setBubbleVisible(group2Index);

	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		let active = group2Index;
		const frameMs = 700;

		window.setInterval(() => {
			frames[active]?.classList.remove('home__mascot-img--active');
			active = (active + 1) % frames.length;
			frames[active]?.classList.add('home__mascot-img--active');
			setBubbleVisible(active);
		}, frameMs);
	}
</script>

<script>
	import gsap from 'gsap';

	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	const animateDecorIn = (el, corner) => {
		const run = () => {
			const w = el.getBoundingClientRect().width || el.offsetWidth || 200;
			const h = el.getBoundingClientRect().height || el.offsetHeight || 200;
			const offscreenX = corner === 'right' ? w + 96 : -(w + 96);
			const offscreenY = -(h + 72);
			const delay = corner === 'right' ? 0.8 : 0.65;

			gsap.set(el, { x: offscreenX, y: offscreenY, autoAlpha: 0, force3D: true });
			gsap.to(el, {
				x: 0,
				y: 0,
				autoAlpha: 1,
				duration: 1.5,
				ease: 'power3.out',
				delay,
			});
		};

		if (reducedMotion.matches) {
			gsap.set(el, { x: 0, y: 0, autoAlpha: 1 });
		} else if (el instanceof HTMLImageElement ? el.complete : true) {
			run();
		} else {
			el.addEventListener('load', run, { once: true });
		}
	};

	const cornerLeaf = document.querySelector('[data-corner-leaf]');
	const topLeaves = document.querySelector('[data-top-leaves]');

	if (cornerLeaf) animateDecorIn(cornerLeaf, 'left');
	if (topLeaves) animateDecorIn(topLeaves, 'right');
</script>

<style>
	.home {
		position: relative;
		box-sizing: border-box;
		width: 100%;
		min-height: 100dvh;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 2rem 0;
		margin: 0 auto;
		overflow-x: clip;
		background: #f8fafc;
		color: #0f172a;
		font-family: Inter, system-ui, sans-serif;
	}

	.home__corner-leaf,
	.home__top-leaves {
		position: fixed;
		top: 0;
		z-index: 2;
		pointer-events: none;
		user-select: none;
		will-change: transform, opacity;
		/* Hidden until GSAP runs (avoids flash before the entrance). */
		opacity: 0;
		visibility: hidden;
	}

	.home__corner-leaf {
		left: 0;
		width: clamp(15rem, 38vw, 28rem);
		height: auto;
		object-fit: contain;
		object-position: left top;
		transform-origin: top left;
	}

	.home__top-leaves {
		right: 0;
		width: clamp(18rem, 48vw, 38rem);
		height: auto;
		object-fit: contain;
		object-position: right top;
		transform-origin: top right;
	}

	.home__content {
		position: relative;
		z-index: 3;
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		width: 100%;
		text-align: center;
	}

	.home__title {
		margin: 0;
		font-size: clamp(2.75rem, 7vw, 4.5rem);
		line-height: 1.1;
		font-weight: 700;
	}

	.home__lead {
		max-width: 28rem;
		margin: 0;
		font-size: 1rem;
		line-height: 1.5;
		color: #475569;
	}

	.home__nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(9rem, 1fr));
		gap: 1rem;
		width: min(100%, 22rem);
		margin: 0 auto;
		justify-items: stretch;
	}

	.home__button {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0.85rem 1.25rem;
		border: 2px solid #0f172a;
		border-radius: 0.5rem;
		background: #fff;
		color: #0f172a;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.home__button:hover {
		background: #0f172a;
		color: #fff;
	}

	.home__button:focus-visible {
		outline: 3px solid #3b82f6;
		outline-offset: 2px;
	}

	/* Box at the bottom of the page that holds the mascot and bubble. */
	.home__mascot {
		position: relative;
		overflow: visible; /* Let the bubble stick out past the box edges. */
		flex-shrink: 0;
		width: min(10rem, 42vw);
		aspect-ratio: 63 / 67;
		margin-top: auto;
		margin-bottom: clamp(1rem, 4vh, 2.5rem);
	}

	.home__mascot-frames {
		position: relative;
		width: 100%;
		height: 100%;
	}

	/* Mascot SVG fills the box and sits on the bottom. */
	.home__mascot-img {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: bottom center;
		opacity: 0;
		transition: opacity 0.12s ease;
	}

	.home__mascot-img--active {
		opacity: 1;
	}

	/* Speech bubble — placed above-right of the beaver, hidden by default. */
	.home__mascot-bubble {
		position: absolute; /* take the bubble out of normal layout so we can place it on top */
		top: -3.75rem; /* move up (more negative = higher) */
		right: -5.25rem; /* move right (more negative = further right) */
		left: auto; /* ignore left so right + top control position */
		z-index: 1; /* draw the bubble above the mascot image */
		width: 9.75rem; /* how wide the bubble image is */
		max-width: none; /* allow the bubble to use the full width above */
		height: auto; /* keep the image proportions */
		object-fit: contain; /* scale the bubble without stretching */
		pointer-events: none; /* clicks pass through to things behind the bubble */
		opacity: 0; /* hidden until the visible class is added */
		transform: none; /* no extra move/scale (use top/right instead) */
		transition: opacity 0.12s ease; /* fade in/out when the frame changes */
	}

	/* Script adds this class when we are on the beaver (Group 2) frame. */
	.home__mascot-bubble--visible {
		opacity: 1; /* show the bubble on the beaver frame */
	}

	@media (max-width: 480px) {
		.home__nav {
			grid-template-columns: 1fr;
			width: 100%;
			max-width: 16rem;
		}

		.home__mascot {
			width: min(8rem, 50vw);
			aspect-ratio: 63 / 67;
		}

		/* Slightly smaller bubble offset on narrow screens. */
		.home__mascot-bubble {
			top: -2.25rem; /* move up on small screens (less than desktop) */
			right: -1.75rem; /* move right on small screens */
			width: 8rem; /* smaller bubble on narrow viewports */
		}

		.home__corner-leaf {
			width: clamp(9rem, 42vw, 14rem);
		}

		.home__top-leaves {
			width: clamp(11rem, 52vw, 20rem);
		}
	}
</style>
