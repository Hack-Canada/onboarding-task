<section class="landing" aria-label="Meet the team">
	<div class="landing__content">
		<p class="landing__eyebrow">Collaboration starts here</p>
		<h1 class="landing__title">Meet the Team</h1>
		<p class="landing__subtitle">
			We design, build, and ship together — turning ideas into products people love.
		</p>
	</div>

	<div class="landing__illustration">
		<img
			class="landing__illustration-fallback"
			src="/meet-the-team.svg"
			alt="Illustration of a team collaborating"
		/>
	</div>

	<a class="landing__cta" href="#team">Explore the team</a>
</section>

<style>
	.landing {
		position: relative;
		--accent: #6c63ff;
		--accent-soft: rgba(108, 99, 255, 0.12);
		--ink: #111827;
		--muted: #4b5563;
		--surface: #ffffff;

		min-height: 100vh;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
		padding: clamp(2rem, 6vw, 5rem);
		background:
			radial-gradient(circle at 15% 20%, var(--accent-soft), transparent 45%),
			radial-gradient(circle at 85% 80%, rgba(255, 185, 185, 0.18), transparent 40%),
			linear-gradient(180deg, #fafbff 0%, #f3f4ff 100%);
		font-family: Inter, system-ui, sans-serif;
		color: var(--ink);
	}

	.landing__content {
		max-width: 34rem;
	}

	.landing__eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.landing__title {
		margin: 0 0 1rem;
		font-size: clamp(2.5rem, 6vw, 4.25rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
		font-weight: 700;
	}

	.landing__subtitle {
		margin: 0;
		max-width: 28rem;
		font-size: clamp(1rem, 2vw, 1.125rem);
		line-height: 1.65;
		color: var(--muted);
	}

	.landing__illustration {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		min-height: 20rem;
	}

	.landing__illustration :global(svg),
	.landing__illustration-fallback {
		width: min(100%, 42rem);
		height: auto;
		will-change: transform;
	}

	.landing__illustration :global(.team-hotspot) {
		cursor: pointer;
	}

	.landing__illustration :global(.team-focus-ring) {
		pointer-events: none;
	}

	.landing__illustration:has(:global(svg)) .landing__illustration-fallback {
		display: none;
	}

	.landing__cta {
		position: absolute;
		left: clamp(2rem, 6vw, 5rem);
		bottom: clamp(2rem, 5vw, 3rem);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.875rem 1.5rem;
		border-radius: 999px;
		background: var(--accent);
		color: var(--surface);
		font-size: 0.9375rem;
		font-weight: 600;
		text-decoration: none;
		box-shadow: 0 12px 30px rgba(108, 99, 255, 0.28);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.landing__cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 36px rgba(108, 99, 255, 0.34);
	}

	@media (max-width: 900px) {
		.landing {
			grid-template-columns: 1fr;
			padding-bottom: 6.5rem;
		}

		.landing__content {
			text-align: center;
			margin-inline: auto;
		}

		.landing__subtitle {
			margin-inline: auto;
		}

		.landing__cta {
			left: 50%;
			transform: translateX(-50%);
		}

		.landing__cta:hover {
			transform: translateX(-50%) translateY(-2px);
		}
	}
</style>

<script>
	import gsap from 'gsap';

	const illustration = document.querySelector('.landing__illustration');

	async function init() {
		if (!illustration) return;

		let svg = illustration.querySelector('svg');

		try {
			const response = await fetch('/meet-the-team.svg');
			if (!response.ok) throw new Error(`SVG request failed (${response.status})`);

			illustration.innerHTML = await response.text();
			svg = illustration.querySelector('svg');
			if (!svg) throw new Error('SVG markup did not include an svg root');
		} catch (error) {
			console.error('Failed to load team illustration', error);
			return;
		}

		svg.setAttribute('role', 'img');
		svg.setAttribute('aria-label', 'Illustration of a team collaborating');
		illustration.removeAttribute('aria-hidden');

		const shapes = svg.querySelectorAll('path, circle, ellipse');
		const accentShapes = svg.querySelectorAll('[fill="#6c63ff"], [fill="#6C63FF"]');
		const cursor = Array.from(svg.querySelectorAll('path')).find((path) =>
			path.getAttribute('d')?.startsWith('M734.688,311.257'),
		);
		const teamMembers = [
			{
				name: 'Design lead',
				card: { x: 56, y: 94, width: 154, height: 112 },
				cursor: { x: 0, y: 0 },
			},
			{
				name: 'Product strategist',
				card: { x: 56, y: 250, width: 154, height: 112 },
				cursor: { x: 0, y: 156 },
			},
			{
				name: 'Engineering lead',
				card: { x: 56, y: 413, width: 154, height: 112 },
				cursor: { x: 0, y: 319 },
			},
		];
		const interactionLayer = createTeamInteractionLayer(svg, teamMembers);

		const mm = gsap.matchMedia();

		mm.add(
			{
				reduceMotion: '(prefers-reduced-motion: reduce)',
				motionSafe: '(prefers-reduced-motion: no-preference)',
			},
			(context) => {
				const { reduceMotion } = context.conditions;

				if (reduceMotion) {
					gsap.set(['.landing__eyebrow', '.landing__title', '.landing__subtitle', svg, '.landing__cta'], {
						autoAlpha: 1,
						y: 0,
						scale: 1,
					});
					selectTeamMember(interactionLayer, 0);
					return;
				}

				gsap.set(shapes, { transformOrigin: '50% 50%' });
				gsap.set(svg, { transformOrigin: '50% 50%' });
				if (cursor) {
					gsap.set(cursor, { transformOrigin: '50% 50%' });
				}

				const intro = gsap.timeline({
					defaults: { ease: 'power3.out' },
				});

				intro
					.from('.landing__eyebrow', { autoAlpha: 0, y: 24, duration: 0.55 })
					.from('.landing__title', { autoAlpha: 0, y: 48, duration: 0.75 }, '-=0.25')
					.from('.landing__subtitle', { autoAlpha: 0, y: 28, duration: 0.55 }, '-=0.35')
					.from(
						svg,
						{
							autoAlpha: 0,
							scale: 0.9,
							y: 36,
							duration: 1,
							ease: 'back.out(1.4)',
						},
						'-=0.25',
					)
					.from(
						shapes,
						{
							autoAlpha: 0,
							scale: 0.96,
							duration: 0.45,
							stagger: {
								amount: 0.9,
								from: 'center',
							},
						},
						'-=0.85',
					)
					.from('.landing__cta', { autoAlpha: 0, y: 18, duration: 0.45 }, '-=0.35');

				gsap.to(svg, {
					y: '-=10',
					duration: 2.8,
					ease: 'sine.inOut',
					repeat: -1,
					yoyo: true,
					delay: 1.4,
				});

				if (accentShapes.length) {
					gsap.fromTo(
						accentShapes,
						{ fill: '#e8e6ff' },
						{
							fill: '#6c63ff',
							duration: 1.2,
							stagger: 0.08,
							ease: 'power2.inOut',
							delay: 0.6,
						},
					);
				}

				const clickLoop = createTeamClickLoop(cursor, interactionLayer);

				return () => {
					intro.kill();
					clickLoop?.kill();
					gsap.killTweensOf([svg, shapes, accentShapes, cursor, ...interactionLayer.frames]);
				};
			},
		);
	}

	function createTeamInteractionLayer(svg, teamMembers) {
		const namespace = 'http://www.w3.org/2000/svg';
		const layer = document.createElementNS(namespace, 'g');
		layer.setAttribute('class', 'team-interaction-layer');
		svg.append(layer);

		const frames = teamMembers.map((member, index) => {
			const frame = document.createElementNS(namespace, 'rect');
			frame.setAttribute('class', 'team-focus-ring');
			frame.setAttribute('x', member.card.x);
			frame.setAttribute('y', member.card.y);
			frame.setAttribute('width', member.card.width);
			frame.setAttribute('height', member.card.height);
			frame.setAttribute('rx', '12');
			frame.setAttribute('fill', 'rgba(108, 99, 255, 0.08)');
			frame.setAttribute('stroke', '#6c63ff');
			frame.setAttribute('stroke-width', '3');
			frame.setAttribute('opacity', '0');
			layer.append(frame);

			const hotspot = document.createElementNS(namespace, 'rect');
			hotspot.setAttribute('class', 'team-hotspot');
			hotspot.setAttribute('x', member.card.x);
			hotspot.setAttribute('y', member.card.y);
			hotspot.setAttribute('width', member.card.width);
			hotspot.setAttribute('height', member.card.height);
			hotspot.setAttribute('rx', '12');
			hotspot.setAttribute('fill', 'transparent');
			hotspot.setAttribute('tabindex', '0');
			hotspot.setAttribute('role', 'button');
			hotspot.setAttribute('aria-label', `Select ${member.name}`);
			hotspot.addEventListener('click', () => selectTeamMember({ frames }, index));
			hotspot.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					selectTeamMember({ frames }, index);
				}
			});
			layer.append(hotspot);

			return frame;
		});

		return { frames, members: teamMembers };
	}

	function createTeamClickLoop(cursor, interactionLayer) {
		if (!cursor) return null;

		const loop = gsap.timeline({
			delay: 2.1,
			repeat: -1,
			repeatDelay: 0.7,
		});

		interactionLayer.members.forEach((member, index) => {
			loop
				.to(cursor, {
					x: member.cursor.x,
					y: member.cursor.y,
					duration: index === 0 ? 0.25 : 0.65,
					ease: 'power2.inOut',
				})
				.to(cursor, {
					scale: 0.88,
					duration: 0.08,
					ease: 'power1.in',
				})
				.add(() => selectTeamMember(interactionLayer, index))
				.to(cursor, {
					scale: 1,
					duration: 0.14,
					ease: 'back.out(2)',
				})
				.to({}, { duration: 0.45 });
		});

		return loop;
	}

	function selectTeamMember(interactionLayer, activeIndex) {
		interactionLayer.frames.forEach((frame, index) => {
			if (index === activeIndex) {
				gsap.fromTo(
					frame,
					{
						autoAlpha: 0.35,
						scale: 0.96,
						transformOrigin: '50% 50%',
					},
					{
						autoAlpha: 1,
						scale: 1,
						duration: 0.28,
						ease: 'back.out(2)',
					},
				);
				return;
			}

			gsap.to(frame, {
				autoAlpha: 0,
				scale: 1,
				duration: 0.2,
				ease: 'power2.out',
			});
		});
	}

	init();
</script>
