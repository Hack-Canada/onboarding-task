---
// Replace label and href with your name when you add your page (for example label: "Faiz", href: "/faiz").
const teamLinks = [
	{ label: 'Name 1', href: '' },
	{ label: 'Name 2', href: '' },
	{ label: 'Name 3', href: '' },
	{ label: 'Name 4', href: '' },
];
---

<main class="home" aria-label="Site showcase">
	<h1 class="home__title">Site showcase</h1>
	<p class="home__lead">
		Onboarding task: build your own page, add it below, and link back to this home screen when you are done.
	</p>

	<nav class="home__nav" aria-label="Showcase pages">
		{
			teamLinks.map((link) => (
				<a class="home__button" href={link.href}>
					{link.label}
				</a>
			))
		}
	</nav>
</main>

<style>
	.home {
		box-sizing: border-box;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		padding: 2rem;
		background-color: #0e2a47;
		background-image: url('/background-pattern.svg');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		color: #f8fafc;
		font-family: Inter, system-ui, sans-serif;
		text-align: center;
	}

	.home__title {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
	}

	.home__lead {
		max-width: 28rem;
		margin: 0;
		font-size: 1rem;
		line-height: 1.5;
		color: #cbd5e1;
	}

	.home__nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(9rem, 1fr));
		gap: 1rem;
		width: min(100%, 22rem);
	}

	.home__button {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0.85rem 1.25rem;
		border: 2px solid #f8fafc;
		border-radius: 0.5rem;
		background: rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(4px);
		color: #f8fafc;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			transform 0.15s ease;
	}

	.home__button:hover {
		background: #f8fafc;
		color: #0e2a47;
		transform: translateY(-2px);
	}

	.home__button:focus-visible {
		outline: 3px solid #93c5fd;
		outline-offset: 2px;
	}

	@media (max-width: 480px) {
		.home__nav {
			grid-template-columns: 1fr;
			width: 100%;
			max-width: 16rem;
		}
	}
</style>
