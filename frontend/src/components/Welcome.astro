---
import group2 from '../assets/Group 2.svg';
import group3 from '../assets/Group 3.svg';
import group4 from '../assets/Group 4.svg';

// Replace label and href with your name when you add your page (for example label: "Faiz", href: "/faiz").
const teamLinks = [
	{ label: 'Name 1', href: '' },
	{ label: 'Name 2', href: '' },
	{ label: 'Name 3', href: '' },
	{ label: 'Name 4', href: '' },
];

const mascotSrcs = [group2.src, group3.src, group4.src];
---

<main class="home" aria-label="Site showcase">
	<div class="home__content">
		<h1 class="home__title">Site showcase</h1>
		<p class="home__lead">
			Onboarding task: build your own page, add it below, and link back to this home screen when you are done.
		</p>

		<nav class="home__nav" aria-label="Showcase pages">
			{
				teamLinks.map((link) => (
					<a class="home__button" href={link.href}>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>

	<div class="home__mascot">
		<img
			class="home__mascot-img"
			data-mascot
			src={group2.src}
			alt=""
			width="63"
			height="67"
			decoding="async"
		/>
	</div>
</main>

<script define:vars={{ mascotSrcs }}>
	const img = document.querySelector('[data-mascot]');
	if (!img || mascotSrcs.length < 2) {
		return;
	}

	if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		return;
	}

	mascotSrcs.forEach((src) => {
		const preload = new Image();
		preload.src = src;
	});

	let frame = 0;
	const frameMs = 700;

	window.setInterval(() => {
		frame = (frame + 1) % mascotSrcs.length;
		img.src = mascotSrcs[frame];
	}, frameMs);
</script>

<style>
	.home {
		box-sizing: border-box;
		width: 100%;
		min-height: 100dvh;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 2rem 0;
		margin: 0 auto;
		background: #f8fafc;
		color: #0f172a;
		font-family: Inter, system-ui, sans-serif;
	}

	.home__content {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		width: 100%;
		text-align: center;
	}

	.home__title {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
	}

	.home__lead {
		max-width: 28rem;
		margin: 0;
		font-size: 1rem;
		line-height: 1.5;
		color: #475569;
	}

	.home__nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(9rem, 1fr));
		gap: 1rem;
		width: min(100%, 22rem);
		margin: 0 auto;
		justify-items: stretch;
	}

	.home__button {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0.85rem 1.25rem;
		border: 2px solid #0f172a;
		border-radius: 0.5rem;
		background: #fff;
		color: #0f172a;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.home__button:hover {
		background: #0f172a;
		color: #fff;
	}

	.home__button:focus-visible {
		outline: 3px solid #3b82f6;
		outline-offset: 2px;
	}

	.home__mascot {
		flex-shrink: 0;
		width: min(10rem, 42vw);
		aspect-ratio: 63 / 67;
		margin-top: auto;
		margin-bottom: clamp(1rem, 4vh, 2.5rem);
	}

	.home__mascot-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: bottom center;
	}

	@media (max-width: 480px) {
		.home__nav {
			grid-template-columns: 1fr;
			width: 100%;
			max-width: 16rem;
		}

		.home__mascot {
			width: min(8rem, 50vw);
			aspect-ratio: 63 / 67;
		}
	}
</style>
